# ==========================================
# FRONTEND CONFIGURATION (Vercel Build / Env)
# ==========================================
# Central API URL config for production and development
VITE_API_BASE_URL=your_public_backend_url_here


# ==========================================
# BACKEND CONFIGURATION (FastAPI / Celery)
# ==========================================
# Execution mode: "inprocess" (for zero-cost free deployment on Render) or "celery" (for worker scale out)
EXECUTION_MODE=inprocess
INPROCESS_MAX_WORKERS=2

# Server port (optional, defaults to 8000)
PORT=8000

# Security secrets
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_MINUTES=10080

# CORS settings (comma-separated list of origins)
CORS_ALLOWED_ORIGINS=https://your-production-domain.vercel.app,http://localhost:3000

# LLM & Search providers
NVIDIA_API_KEY=your_nvidia_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# PostgreSQL or SQLite connection string
DATABASE_URL=postgresql+psycopg://quillops:quillops@postgres:5432/quillops
# Local SQLite fallback:
# DATABASE_URL=sqlite:///./quillops.db

# Redis connection string
REDIS_URL=redis://redis:6379/0
# Local Redis fallback:
# REDIS_URL=redis://localhost:6379/0
