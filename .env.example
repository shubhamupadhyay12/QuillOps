NVIDIA_API_KEY=your_nvidia_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_MINUTES=10080

# Database — defaults to postgres container or local sqlite URL
DATABASE_URL=postgresql+psycopg://quillops:quillops@postgres:5432/quillops
# Local SQLite fallback for non-docker runs:
# DATABASE_URL=sqlite:///./quillops.db

# Redis — defaults to redis container
REDIS_URL=redis://redis:6379/0
# Local Redis fallback:
# REDIS_URL=redis://localhost:6379/0

ALLOWED_ORIGINS=http://localhost:3000
